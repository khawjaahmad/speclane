# Copy to .env (gitignored). Fill in only the provider(s) you use.
# SpecLane never reads secrets from anywhere but the environment.

# ---------------------------------------------------------------------------
# Anthropic (Claude) — first-party Claude Code
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL is only needed to override the default Anthropic endpoint.

# ---------------------------------------------------------------------------
# OpenAI-compatible (OpenAI, OpenRouter, local servers, etc.)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Examples:
#   OpenRouter:  https://openrouter.ai/api/v1
#   Ollama:      http://localhost:11434/v1
#   LM Studio:   http://localhost:1234/v1

# ---------------------------------------------------------------------------
# z.ai GLM Coding Plan — verify current values at docs.z.ai
# Two protocol families; use the one your agent speaks.
# ---------------------------------------------------------------------------
ZAI_API_KEY=

# (a) Anthropic-compatible — drop-in for Claude Code / Goose-style harnesses.
#     Note: z.ai uses ANTHROPIC_AUTH_TOKEN (not ANTHROPIC_API_KEY).
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# ANTHROPIC_AUTH_TOKEN=${ZAI_API_KEY}
# API_TIMEOUT_MS=3000000      # long-context GLM calls need a large client timeout

# (b) OpenAI-compatible — for Codex/Cursor/Cline/OpenCode.
#     Coding Plan quota REQUIRES the coding endpoint:
# OPENAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
# OPENAI_API_KEY=${ZAI_API_KEY}
#     General (non-Coding-Plan) endpoint is https://api.z.ai/api/paas/v4
